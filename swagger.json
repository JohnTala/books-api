{
  "swagger": "2.0",
  "info": {
    "title": "Books API",
    "description": "API documentation for the Books project",
    "version": "1.0.0"
  },
  "host": "books-api-189e.onrender.com",
  "basePath": "/",
  "schemes": ["https"],
  "consumes": ["application/json"],
  "produces": ["application/json"],
  "paths": {
    "/": {
      "get": {
        "tags": ["Root"],
        "description": "Welcome endpoint",
        "responses": {
          "200": {
            "description": "OK",
            "examples": {
              "application/json": {
                "message": "Welcome to Books API. Use /books to get all books."
              }
            }
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/books": {
      "get": {
        "tags": ["Books"],
        "description": "Get all books",
        "responses": {
          "200": { "description": "OK" },
          "500": { "description": "Internal Server Error" }
        }
      },
      "post": {
        "tags": ["Books"],
        "description": "Create a new book",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": ["title", "author", "genre", "publishedYear", "rating"],
              "properties": {
                "title": { "example": "Example Book" },
                "author": { "example": "Tariq Ramadan" },
                "genre": { "example": "Philosophy / Religion / Essay" },
                "publishedYear": { "example": 2009 },
                "pages": { "example": 240 },
                "rating": { "example": 4.3 }
              }
            }
          }
        ],
        "responses": {
          "201": { "description": "Created" },
          "400": { "description": "Bad Request" },
          "500": { "description": "Internal Server Error" }
        }
      }
    },
    "/books/{id}": {
      "get": {
        "tags": ["Books"],
        "description": "Get a single book by ID",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { "description": "OK" },
          "404": { "description": "Not Found" },
          "500": { "description": "Internal Server Error" }
        }
      },
      "put": {
        "tags": ["Books"],
        "description": "Update a book by ID",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": ["title", "author", "genre", "publishedYear", "rating"],
              "properties": {
                "title": { "example": "Updated Book" },
                "author": { "example": "Updated Author" },
                "genre": { "example": "Updated Genre" },
                "publishedYear": { "example": 2010 },
                "pages": { "example": 300 },
                "rating": { "example": 4.7 }
              }
            }
          }
        ],
        "responses": {
          "200": { "description": "OK" },
          "400": { "description": "Bad Request" },
          "404": { "description": "Not Found" },
          "500": { "description": "Internal Server Error" }
        }
      },
      "delete": {
        "tags": ["Books"],
        "description": "Delete a book by ID",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { "description": "OK" },
          "400": { "description": "Bad Request" },
          "500": { "description": "Internal Server Error" }
        }
      }
    }
  }
}
